APP_NAME="Smash Up Randomizer"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://smash-up-randomizer.ddev.site
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=db
DB_USERNAME=db
DB_PASSWORD=db

BROADCAST_DRIVER=log
CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Mail: default is SMTP (local Mailpit). Production — Brevo like Issue Forge: HTTP API (no SMTP ports).
# Brevo API: MAIL_MAILER=brevo and BREVO_API_KEY= (from Brevo dashboard; transactional key)
# Classic SMTP: MAIL_MAILER=smtp, e.g. Brevo relay:
# MAIL_HOST=smtp-relay.brevo.com
# MAIL_PORT=587
# MAIL_USERNAME=your-brevo-smtp-login
# MAIL_PASSWORD=your-smtp-key
# MAIL_ENCRYPTION=tls
BREVO_API_KEY=
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
# Optional: addresses for php artisan email:test and scheduler failure notifications
MAIL_TEST_EMAIL=info@smash-up-randomizer.com
MAIL_ADMIN_EMAIL=info@smash-up-randomizer.com

MATOMO_ENABLED=true
MATOMO_SITE_ID=1
MATOMO_TRACKER_URL=https://analytics.kadsuno.com

# Sentry (optional): leave empty to disable
SENTRY_LARAVEL_DSN=

# AI text rewrite for factions:rewrite command
# Provider: "groq" (free at console.groq.com) or "gemini" (free at aistudio.google.com)
AI_REWRITE_PROVIDER=groq
AI_REWRITE_KEY=
AI_REWRITE_MODEL=llama-3.3-70b-versatile
